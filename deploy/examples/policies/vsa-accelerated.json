{
  "trust": {
    "builders": [
      {
        "id": "https://github.com/actions/runner",
        "maxLevel": 3
      }
    ],
    "verifiers": [
      {
        "id": "https://verifier.internal/prod",
        "key": "/etc/nri-supply-chain/keys/verifier.pub"
      }
    ],
    "issuers": ["https://token.actions.githubusercontent.com"],
    "sanPatterns": ["*@myorg.com", "https://github.com/myorg/*"]
  },
  "slsa": {
    "missingPolicy": "deny"
  },
  "vex": {
    "missingPolicy": "allow"
  },
  "vsa": {
    "minimumLevel": 2,
    "maxAge": "24h",
    "policy": "https://example.com/production-policy"
  },
  "signatures": {
    "requireTransparencyLog": false
  }
}
